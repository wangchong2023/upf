#!/bin/bash
# .githooks/pre-commit: 提交前强制执行文档同步与一致性检查

echo "Running Pre-commit Quality Gate: Documentation Sync & Check..."

# 1. 尝试自动同步
make doc-sync

# 2. 运行一致性校验
./scripts/auto-doc-check.sh

RESULT=$?

if [ $RESULT -ne 0 ]; then
    echo "❌ [ERROR] Documentation consistency check failed!"
    exit 1
fi

echo "✅ [SUCCESS] Documentation is synced and valid. Proceeding with commit..."
exit 0
